# Database
DATABASE_URL=postgres://user:password@localhost:5432/interview_coach

# Session signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_secret

# OpenAI API (or Replit AI Integrations key)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Server port (API server)
PORT=8080

# Frontend Vite base path
BASE_PATH=/
